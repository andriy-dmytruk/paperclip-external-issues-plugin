{
  "name": "paperclip-jira-plugin",
  "version": "0.1.0",
  "description": "Paperclip plugin for synchronizing Jira issues into Paperclip projects.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvarosanchez/paperclip-jira-plugin.git"
  },
  "homepage": "https://github.com/alvarosanchez/paperclip-jira-plugin#readme",
  "bugs": {
    "url": "https://github.com/alvarosanchez/paperclip-jira-plugin/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "node ./scripts/build.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "prepack": "pnpm build",
    "test": "node --test tests/build-script.spec.mjs && tsx --test tests/plugin.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.416.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "esbuild": "0.28.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
