{
  "name": "paperclip-external-issues-plugin",
  "version": "0.1.2",
  "description": "Paperclip plugin for synchronizing Jira Data Center, Jira Cloud, or GitHub issues into Paperclip.",
  "author": "Andriy Dmytruk",
  "contributors": [
    "Álvaro Sánchez-Mariscal"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvarosanchez/paperclip-external-issues-plugin.git"
  },
  "homepage": "https://github.com/alvarosanchez/paperclip-external-issues-plugin#readme",
  "bugs": {
    "url": "https://github.com/alvarosanchez/paperclip-external-issues-plugin/issues"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "issues",
    "issue-sync",
    "issue-tracker",
    "jira",
    "jira data center",
    "jira cloud",
    "github",
    "github issues",
    "sync"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "node ./scripts/build.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "jira:fetch-wadl": "node --import tsx ./scripts/jira-dc/fetch-wadl.ts",
    "jira:convert-wadl": "node --import tsx ./scripts/jira-dc/convert-wadl.ts",
    "jira:sync-spec": "node --import tsx ./scripts/jira-dc/sync-spec.ts",
    "jira:generate-client": "node --import tsx ./scripts/jira-dc/generate-client.ts",
    "prepack": "pnpm build",
    "test": "node --test tests/build-script.spec.mjs && tsx --test tests/plugin.spec.ts tests/jira-wadl.spec.ts tests/sync/*.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@paperclipai/plugin-sdk": "^2026.416.0",
    "lucide-react": "^0.574.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "esbuild": "0.28.0",
    "fast-xml-parser": "^5.7.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "openapiGeneratorCli": {
    "version": "7.16.0"
  }
}
